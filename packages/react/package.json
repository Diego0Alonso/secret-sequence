{
  "name": "secret-sequence-react",
  "version": "1.0.0",
  "description": "React hook & component wrapper for secret-sequence-core — detect directional sequences, key combos, and touch gestures",
  "keywords": [
    "react",
    "hook",
    "keyboard",
    "stratagem",
    "konami",
    "sequence",
    "shortcut",
    "input-engine",
    "helldivers",
    "key-combo",
    "easter-egg",
    "typescript",
    "touch",
    "gesture"
  ],
  "author": "diego0alonso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diego0alonso/secret-sequence.git",
    "directory": "packages/react"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "secret-sequence-core": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "secret-sequence-core": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}